<!DOCTYPE html>
<html>

<head>

<title>Dashboard - EduVerse</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-5">


<!-- HERO WELCOME SECTION -->

<div class="p-4 mb-4 bg-light rounded-3 shadow-sm">

<div class="container-fluid py-2">

<h2 class="display-6 fw-bold">
Welcome back, <%= user.name %> 👋
</h2>

<p class="text-muted">
Continue your learning journey on EduVerse.
</p>

<a href="/courses" class="btn btn-dark">
Browse Courses
</a>

</div>

</div>


<!-- STATS CARDS -->

<div class="row mb-5">

<div class="col-md-4 mb-3">

<div class="card shadow-sm text-center">

<div class="card-body">

<h6 class="text-muted">Enrolled Courses</h6>

<h2 class="fw-bold"><%= user.enrolledCourses.length %></h2>

</div>

</div>

</div>

<div class="col-md-4 mb-3">

<div class="card shadow-sm text-center">

<div class="card-body">

<h6 class="text-muted">Completed Lessons</h6>

<h2 class="fw-bold"><%= user.completedLessons.length %></h2>

</div>

</div>

</div>

<div class="col-md-4 mb-3">

<div class="card shadow-sm text-center">

<div class="card-body">

<h6 class="text-muted">Platform</h6>

<h5 class="fw-bold">EduVerse LMS</h5>

</div>

</div>

</div>

</div>


<!-- MY COURSES -->

<h4 class="mb-4">My Courses</h4>

<% if (user.enrolledCourses.length === 0) { %>

<div class="alert alert-info">

You haven't enrolled in any courses yet.

</div>

<a href="/courses" class="btn btn-dark">
Explore Courses
</a>

<% } else { %>

<div class="row">

<% user.enrolledCourses.forEach(course => { %>

<div class="col-md-4 mb-4">

<div class="card shadow-sm h-100">

<img 
src="<%= course.thumbnail || 'https://images.unsplash.com/photo-1518770660439-4636190af475' %>"
class="card-img-top"
style="height:180px; object-fit:cover;">


<div class="card-body d-flex flex-column">

<h5 class="card-title"><%= course.title %></h5>

<p class="text-muted small mb-3">
Instructor: <%= course.teacher?.name || "EduVerse" %>
</p>

<div class="mt-auto">

<a href="/courses/<%= course._id %>" class="btn btn-primary btn-sm">
Continue Course
</a>

</div>

</div>

</div>

</div>

<% }) %>

</div>

<% } %>


<div class="mt-4">

<a href="/courses" class="btn btn-outline-dark">
Explore More Courses
</a>

</div>

</div>


<%- include("partials/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>