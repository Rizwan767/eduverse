<!DOCTYPE html>
<html>

<head>
<title>Dashboard - EduVerse</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<style>
  body {
    background-color: #f8f9fa;
  }

  .card {
    border-radius: 12px;
    transition: 0.2s;
  }

  .card:hover {
    transform: translateY(-4px);
  }

  .progress {
    border-radius: 10px;
  }
</style>

</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-5 fade-in">
<!-- 🔥 HERO SECTION -->
<div class="p-4 mb-4 bg-white rounded-3 shadow-sm">

<div class="container-fluid py-2">

<h2 class="fw-bold">
  Welcome, <%= user.name %>

  <% if (user.role === "admin") { %>
    <span class="badge bg-danger ms-2">Admin</span>
  <% } else if (user.role === "teacher") { %>
    <span class="badge bg-primary ms-2">Teacher</span>
  <% } else { %>
    <span class="badge bg-success ms-2">Student</span>
  <% } %>
</h2>

<p class="text-muted mb-3">
Continue your learning journey on EduVerse 🚀
</p>

<a href="/courses" class="btn btn-dark btn-sm">
Browse Courses
</a>

</div>
</div>


<!-- 🔥 STATS -->
<div class="row mb-5">

<div class="col-md-4 mb-3">
<div class="card shadow-sm text-center p-3">
<h6 class="text-muted">📚 Enrolled Courses</h6>
<h2 class="fw-bold"><%= user.enrolledCourses.length %></h2>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="card shadow-sm text-center p-3">
<h6 class="text-muted">✅ Completed Lessons</h6>
<h2 class="fw-bold"><%= user.completedLessons.length %></h2>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="card shadow-sm text-center p-3">
<h6 class="text-muted">🎓 Platform</h6>
<h5 class="fw-bold">EduVerse LMS</h5>
</div>
</div>

</div>


<!-- 🔥 MY COURSES -->
<h4 class="mb-4">📖 My Courses</h4>

<% if (user.enrolledCourses.length === 0) { %>

<div class="alert alert-info shadow-sm">
You haven't enrolled in any courses yet.
</div>

<a href="/courses" class="btn btn-dark btn-sm">
Explore Courses
</a>

<% } else { %>

<div class="row">

<% user.enrolledCourses.forEach(course => { %>

<div class="col-md-4 mb-4">

<div class="card shadow-sm h-100">

<img 
src="<%= course.thumbnail || 'https://images.unsplash.com/photo-1518770660439-4636190af475' %>"
class="card-img-top"
style="height:180px; object-fit:cover; border-top-left-radius:12px; border-top-right-radius:12px;">


<div class="card-body d-flex flex-column">

<h5 class="card-title"><%= course.title %></h5>

<p class="text-muted small mb-2">
Instructor: <%= course.teacher?.name || "EduVerse" %>
</p>

<%
const totalLessons = course.lessons.length;

const completedCount = course.lessons.filter(lesson =>
  user.completedLessons.some(id => id.toString() === lesson._id.toString())
).length;

const progress = totalLessons === 0 ? 0 : Math.round((completedCount / totalLessons) * 100);
%>

<!-- Progress -->
<div class="progress mb-2" style="height: 8px;">
  <div 
    class="progress-bar bg-success"
    style="width: <%= progress %>%;">
  </div>
</div>

<p class="small text-muted mb-3">
<%= progress %>% completed
</p>

<div class="mt-auto">

<a href="/courses/<%= course._id %>" class="btn btn-primary btn-sm w-100">
Continue Course
</a>

</div>

</div>
</div>

</div>

<% }) %>

</div>

<% } %>


<!-- 🔥 FOOT ACTION -->
<div class="text-center mt-4">

<a href="/courses" class="btn btn-outline-dark btn-sm">
Explore More Courses
</a>

</div>

</div>


<%- include("partials/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>