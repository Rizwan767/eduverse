<!DOCTYPE html>
<html>
  <head>
    <title>Add Lesson - EduVerse</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <%- include("partials/navbar") %>

    <div class="container mt-5 fade-in" style="max-width: 700px">
      <h2 class="mb-4 text-center">Add Lesson to <%= course.title %></h2>

      <!-- 🔥 IMPORTANT: enctype added -->
      <form
        action="/courses/<%= course._id %>/lessons"
        method="POST"
        enctype="multipart/form-data"
      >
        <!-- TITLE -->
        <div class="mb-3">
          <label class="form-label">Lesson Title</label>
          <input
            type="text"
            name="title"
            class="form-control"
            placeholder="Enter lesson title"
            required
          />
        </div>

        <!-- VIDEO -->
        <div class="mb-3">
          <label class="form-label">YouTube Video URL</label>
          <input
            type="text"
            name="videoUrl"
            class="form-control"
            placeholder="Paste YouTube link"
            required
          />
        </div>

        <!-- DESCRIPTION -->
        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea
            name="description"
            class="form-control"
            rows="3"
            placeholder="Enter lesson description"
          ></textarea>
        </div>

        <!-- 📄 NOTES FILE -->
        <div class="mb-3">
          <label class="form-label">Upload Notes (PDF / DOCX)</label>
          <input
            type="file"
            name="pdfNotes"
            class="form-control"
            accept=".pdf,.doc,.docx"
          />
        </div>

        <!-- 📝 ASSIGNMENT FILE -->
        <div class="mb-3">
          <label class="form-label">Upload Assignment (PDF / DOCX)</label>
          <input
            type="file"
            name="assignment"
            class="form-control"
            accept=".pdf,.doc,.docx"
          />
        </div>

        <button type="submit" class="btn btn-dark w-100">Add Lesson</button>
      </form>

      <div class="text-center mt-3">
        <a href="/courses" class="btn btn-outline-secondary">
          Back to Courses
        </a>
      </div>
    </div>

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
