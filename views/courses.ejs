<!DOCTYPE html>
<html>

<head>

<title>Courses - EduVerse</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<style>
  body {
    background-color: #f8f9fa;
  }

  .card {
    border-radius: 12px;
    transition: 0.2s;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .course-img {
    height: 180px;
    object-fit: cover;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
  }
</style>

</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-5 fade-in">
<!-- 🔥 HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">

  <h2 class="fw-bold">📚 Explore Courses</h2>

  <% if (user.role === "admin" || user.role === "teacher") { %>
    <a href="/courses/new" class="btn btn-dark btn-sm">
      + Create Course
    </a>
  <% } %>

</div>

<!-- 🔥 COURSES GRID -->
<div class="row">

<% courses.forEach(course => { %>

<div class="col-md-4 mb-4">

<div class="card shadow-sm h-100">

<!-- Image -->
<img 
src="<%= course.thumbnail || 'https://images.unsplash.com/photo-1518770660439-4636190af475' %>"
class="course-img">

<div class="card-body d-flex flex-column">

<h5 class="card-title fw-bold"><%= course.title %></h5>

<p class="card-text text-muted small">
<%= course.description.length > 100 ? course.description.substring(0, 100) + "..." : course.description %>
</p>

<p class="text-muted small mb-2">
👨‍🏫 <%= course.teacher?.name || "EduVerse" %>
</p>

<%
const enrolled = user.enrolledCourses.some(
id => id.toString() === course._id.toString()
);
%>

<div class="mt-auto d-flex flex-wrap gap-2">

<a href="/courses/<%= course._id %>" class="btn btn-primary btn-sm">
View
</a>

<% if (user.role === "admin" || user.role === "teacher") { %>
<a href="/courses/<%= course._id %>/lessons/new" class="btn btn-outline-dark btn-sm">
Add Lesson
</a>
<% } %>

<% if (enrolled) { %>

<button class="btn btn-success btn-sm" disabled>
✔ Enrolled
</button>

<% } else { %>

<form action="/courses/<%= course._id %>/enroll" method="POST">

<button class="btn btn-dark btn-sm">
Enroll
</button>

</form>

<% } %>

</div>

</div>

</div>

</div>

<% }) %>

</div>

<!-- 🔥 FOOT ACTION -->
<div class="text-center mt-4">

<a href="/dashboard" class="btn btn-outline-secondary btn-sm">
← Back to Dashboard
</a>

</div>

</div>

<%- include("partials/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>