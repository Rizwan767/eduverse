<!DOCTYPE html>
<html>

<head>

<title>Courses - EduVerse</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-5">

<h2 class="mb-4">Available Courses</h2>

<% if (user.role === "admin" || user.role === "teacher") { %>

<a href="/courses/new" class="btn btn-dark mb-4">
Create Course
</a>

<% } %>


<div class="row">

<% courses.forEach(course => { %>

<div class="col-md-4 mb-4">

<div class="card shadow-sm h-100">

<!-- Course Image -->
<img 
src="<%= course.thumbnail || 'https://images.unsplash.com/photo-1518770660439-4636190af475' %>"
class="card-img-top"
style="height:180px; object-fit:cover;">

<div class="card-body d-flex flex-column">

<h5 class="card-title"><%= course.title %></h5>

<p class="card-text text-muted">
<%= course.description %>
</p>

<p class="text-muted small">
Instructor: <%= course.teacher?.name || "EduVerse" %>
</p>

<%
const enrolled = user.enrolledCourses.some(
id => id.toString() === course._id.toString()
);
%>


<div class="mt-auto">

<a href="/courses/<%= course._id %>" class="btn btn-primary btn-sm">
View Course
</a>

<% if (user.role === "admin" || user.role === "teacher") { %>

<a href="/courses/<%= course._id %>/lessons/new" class="btn btn-outline-dark btn-sm">
Add Lesson
</a>

<% } %>


<% if (enrolled) { %>

<button class="btn btn-success btn-sm" disabled>
Enrolled ✓
</button>

<% } else { %>

<form action="/courses/<%= course._id %>/enroll" method="POST" style="display:inline;">

<button class="btn btn-dark btn-sm">
Enroll
</button>

</form>

<% } %>

</div>

</div>

</div>

</div>

<% }) %>

</div>


<a href="/dashboard" class="btn btn-outline-secondary mt-3">
Back to Dashboard
</a>

</div>
<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>