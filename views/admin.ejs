<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      background-color: #f8f9fa;
    }
    .section-title {
      margin-top: 30px;
      margin-bottom: 15px;
    }
  </style>
</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-4">

  <!-- 🔥 TITLE -->
  <h1 class="mb-4">⚙️ Admin Panel</h1>

  <!-- ================= STATS ================= -->
  <div class="row mb-4">

    <div class="col-md-4">
      <div class="card text-center shadow-sm p-3">
        <h6 class="text-muted">👥 Users</h6>
        <h2><%= totalUsers %></h2>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-center shadow-sm p-3">
        <h6 class="text-muted">📚 Courses</h6>
        <h2><%= totalCourses %></h2>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-center shadow-sm p-3">
        <h6 class="text-muted">🎓 Enrollments</h6>
        <h2><%= totalEnrollments %></h2>
      </div>
    </div>

  </div>

  <!-- ================= USERS ================= -->
  <h3 class="section-title">👤 Users</h3>

  <% users.forEach(user => { %>

    <div class="card shadow-sm mb-3 p-3">

      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-1"><%= user.name %></h5>
          <small class="text-muted"><%= user.email %></small>
        </div>

        <span class="badge bg-secondary text-uppercase">
          <%= user.role %>
        </span>
      </div>

      <!-- Role Update -->
      <form method="POST" action="/admin/user/<%= user._id %>/role" class="mt-3 d-flex gap-2">

        <select name="role" class="form-select w-auto">
          <option value="student" <%= user.role === "student" ? "selected" : "" %>>Student</option>
          <option value="teacher" <%= user.role === "teacher" ? "selected" : "" %>>Teacher</option>
          <option value="admin" <%= user.role === "admin" ? "selected" : "" %>>Admin</option>
        </select>

        <% if (user._id.toString() !== currentUserId.toString()) { %>
          <button class="btn btn-primary btn-sm">Update</button>
        <% } else { %>
          <button class="btn btn-secondary btn-sm" disabled>Cannot change self</button>
        <% } %>

      </form>

      <!-- Courses -->
      <div class="mt-3">
        <strong>Enrolled Courses:</strong>

        <% if (user.enrolledCourses.length === 0) { %>
          <p class="text-muted">No courses enrolled</p>
        <% } else { %>

          <ul class="mt-2">
            <% user.enrolledCourses.forEach(course => { %>

              <% 
                const totalLessons = course.lessons.length;
                const completed = user.completedLessons.filter(lessonId =>
                  course.lessons.some(lesson => lesson._id.toString() === lessonId.toString())
                ).length;

                const progress = totalLessons === 0 ? 0 : Math.round((completed / totalLessons) * 100);
              %>

              <li>
                <strong><%= course.title %></strong>
                — <%= progress %>%

                <% if (progress === 100) { %>
                  <span class="text-success">✔</span>
                <% } else { %>
                  <span class="text-danger">✖</span>
                <% } %>
              </li>

            <% }) %>
          </ul>

        <% } %>
      </div>

    </div>

  <% }) %>

  <!-- ================= COURSES ================= -->
  <h3 class="section-title">📚 Courses</h3>

  <% courses.forEach(course => { %>

    <div class="card shadow-sm mb-3 p-3">

      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><%= course.title %></h5>

        <form method="POST" action="/courses/<%= course._id %>/delete">
          <button class="btn btn-danger btn-sm">Delete</button>
        </form>
      </div>

      <p class="mt-2 mb-1">
        <strong>Instructor:</strong> <%= course.teacher?.name || "No Instructor" %>
      </p>

      <p>
        <strong>Students:</strong>
        <%= users.filter(user =>
          user.enrolledCourses.some(c => c._id.toString() === course._id.toString())
        ).length %>
      </p>

      <a href="/admin/course/<%= course._id %>" class="btn btn-outline-primary btn-sm">
        View Students
      </a>

    </div>

  <% }) %>

</div>

</body>
</html>