<!DOCTYPE html>
<html>

<head>

<title><%= course.title %> - EduVerse</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<style>
  body {
    background-color: #f8f9fa;
  }

  .sidebar {
    height: 85vh;
    overflow-y: auto;
    border-right: 1px solid #ddd;
  }

  .lesson-item {
    cursor: pointer;
    border-radius: 10px;
    transition: 0.2s;
  }

  .lesson-item:hover {
    background-color: #f1f1f1;
    transform: translateX(5px);
  }

  .video-container {
    max-width: 900px;
  }

  .card {
    border-radius: 12px;
  }
</style>

</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-5 fade-in">
<div class="row">

<!-- 🔥 SIDEBAR -->
<div class="col-md-3 sidebar p-3 bg-white">

<h5 class="mb-3 fw-bold">📚 Lessons</h5>

<% course.lessons.forEach((lesson,index)=>{ %>

<div class="card mb-2 lesson-item p-2" onclick="loadLesson(<%= index %>)">

  <strong><%= lesson.title %></strong>

  <!-- 🔥 NEW: content indicators -->
  <div class="small text-muted mt-1">
    🎥 Video
    <% if (lesson.pdfNotes) { %>
      | 📄 Notes
    <% } %>
    <% if (lesson.assignment) { %>
      | 📝 Assignment
    <% } %>
  </div>

  <!-- 🔥 KEEP YOUR DELETE BUTTON -->
  <% if (user && (user.role === "admin" || user._id.toString() === course.teacher.toString())) { %>
    <form method="POST" action="/courses/<%= course._id %>/lessons/<%= lesson._id %>/delete" class="mt-2">
  <button 
    onclick="event.stopPropagation()" 
    class="btn btn-danger btn-sm w-100">
    Delete
  </button>
</form>
  <% } %>

</div>
<% }) %>

</div>


<!-- 🔥 MAIN CONTENT -->
<div class="col-md-9 p-4">

<!-- 🎓 CERTIFICATE -->
<div class="mb-4">

  <% if (progress === 100) { %>
    <a href="/courses/<%= course._id %>/certificate" class="btn btn-success">
      🎓 Download Certificate
    </a>
  <% } else { %>
    <button class="btn btn-secondary" disabled>
      🔒 Complete course to unlock certificate
    </button>
  <% } %>

</div>

<!-- 🔥 LESSON TITLE -->
<h3 id="lessonTitle" class="fw-bold"></h3>

<p id="lessonDesc" class="text-muted mb-3"></p>

<!-- 🎥 VIDEO -->
<div class="video-container mb-4">

<div class="ratio ratio-16x9 shadow-sm rounded">
<iframe id="lessonVideo" frameborder="0" allowfullscreen></iframe>
</div>

</div>

<!-- 📄 NOTES -->
<div id="lessonNotes" class="mb-3"></div>

<!-- 📝 ASSIGNMENT -->
<div id="lessonAssignment" class="mb-3"></div>

<!-- ✅ COMPLETE -->
<div id="lessonComplete"></div>

</div>

</div>

</div>

<%- include("partials/footer") %>

<script>

const lessons = <%- JSON.stringify(course.lessons) %>;
const courseId = "<%= course._id %>";
const completedLessons = <%- JSON.stringify(user.completedLessons) %>;

function getVideoId(url){
  if(url.includes("watch?v=")){
    return url.split("watch?v=")[1].split("&")[0];
  }
  if(url.includes("youtu.be/")){
    return url.split("youtu.be/")[1].split("?")[0];
  }
  return "";
}

function loadLesson(index){
 // 🔥 ADD THIS PART HERE (TOP OF FUNCTION)

  // remove active from all
  document.querySelectorAll(".lesson-item").forEach(el => {
    el.classList.remove("active");
  });

  // add active to clicked one
  document.querySelectorAll(".lesson-item")[index].classList.add("active");

  const lesson = lessons[index];

  document.getElementById("lessonTitle").innerText = lesson.title;
  document.getElementById("lessonDesc").innerText = lesson.description || "";

  const videoId = getVideoId(lesson.videoUrl);

  document.getElementById("lessonVideo").src =
  "https://www.youtube.com/embed/" + videoId;

  /* NOTES */
  if(lesson.pdfNotes){
    document.getElementById("lessonNotes").innerHTML =
    `<a href="${lesson.pdfNotes}" target="_blank" class="btn btn-info">📄 View Notes</a>`;
  } else {
    document.getElementById("lessonNotes").innerHTML="";
  }

  /* ASSIGNMENT */
if(lesson.assignment){
  document.getElementById("lessonAssignment").innerHTML =
  `<a href="${lesson.assignment}" target="_blank" class="btn btn-warning">📝 View Assignment</a>`;
} else {
  document.getElementById("lessonAssignment").innerHTML="";
}

  /* COMPLETE BUTTON */
  if(completedLessons.includes(lesson._id)){
    document.getElementById("lessonComplete").innerHTML =
    `<button class="btn btn-secondary" disabled>Completed ✅</button>`;
  } else {
    document.getElementById("lessonComplete").innerHTML =
    `<form method="POST" action="/courses/${courseId}/lessons/${lesson._id}/complete">
      <button class="btn btn-primary">Mark Complete</button>
    </form>`;
  }

}

/* Load first lesson */
if(lessons.length > 0){
  loadLesson(0);
}

</script>

</body>
</html>